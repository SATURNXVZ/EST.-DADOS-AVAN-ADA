{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compilar C",
            "type": "shell",
            "command": "C:\\msys64\\ucrt64\\bin\\gcc.exe",
            "args": [
                "-Wall",
                "-Wextra", 
                "-g3",
                "${file}",
                "-o",
                "${fileDirname}\\output\\${fileBasenameNoExtension}.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "Rodar",
            "type": "shell",
            "command": "${fileDirname}\\output\\${fileBasenameNoExtension}.exe",
            "dependsOn": "Compilar C",
            "group": {
                "kind": "test",
                "isDefault": true
            }
        }
    ]
}